<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — Ở Đây Có Yên</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen">
<%- include('partials/nav') %>

<main class="max-w-7xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold text-gray-800 mb-6">Dashboard</h1>

  <!-- Stats Grid -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
    <div class="bg-white rounded-xl shadow-sm p-5 border border-gray-100">
      <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Tổng Sources</p>
      <p class="text-3xl font-bold text-gray-800"><%= stats.totalSources %></p>
      <p class="text-xs text-gray-400 mt-1">Video, ảnh, quotes</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-5 border border-gray-100">
      <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Draft</p>
      <p class="text-3xl font-bold text-amber-500"><%= stats.draft %></p>
      <p class="text-xs text-gray-400 mt-1">Video chưa xuất bản</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-5 border border-gray-100">
      <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Scheduled</p>
      <p class="text-3xl font-bold text-blue-500"><%= stats.scheduled %></p>
      <p class="text-xs text-gray-400 mt-1">Sắp đăng</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-5 border border-gray-100">
      <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Published</p>
      <p class="text-3xl font-bold text-green-500"><%= stats.published %></p>
      <p class="text-xs text-gray-400 mt-1">Đã đăng lên TikTok</p>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-6">
    <!-- Tổng quan -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100">
      <div class="px-5 py-4 border-b">
        <h2 class="font-semibold text-gray-700">Tổng quan</h2>
      </div>
      <div class="px-5 py-4 space-y-2">
        <div class="flex justify-between text-sm">
          <span class="text-gray-500">Tổng videos</span>
          <span class="font-medium"><%= stats.totalVideos %></span>
        </div>
        <div class="flex justify-between text-sm">
          <span class="text-gray-500">Tổng posts đã lên lịch</span>
          <span class="font-medium"><%= stats.totalPosts %></span>
        </div>
      </div>
    </div>

    <!-- Lịch đăng tới -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100">
      <div class="flex items-center justify-between px-5 py-4 border-b">
        <h2 class="font-semibold text-gray-700">Lịch đăng tới</h2>
        <a href="/schedule" class="text-teal-600 text-sm hover:underline">Xem tất cả →</a>
      </div>
      <div class="divide-y">
        <% if (!stats.upcoming || stats.upcoming.length === 0) { %>
          <p class="px-5 py-4 text-gray-400 text-sm">Chưa có lịch đăng. <a href="/schedule" class="text-teal-600 hover:underline">Lên lịch →</a></p>
        <% } else { %>
          <% stats.upcoming.forEach(p => { %>
            <div class="px-5 py-3 hover:bg-gray-50">
              <p class="text-sm font-medium text-gray-800"><%= p.video_title || '(Chưa gắn video)' %></p>
              <p class="text-xs text-gray-400"><%= new Date(p.scheduled_date).toLocaleString('vi-VN') %></p>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Quick actions -->
  <div class="mt-6 flex flex-wrap gap-3">
    <a href="/sources" class="inline-flex items-center gap-2 bg-teal-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-teal-700 transition-colors">
      <span>📁</span> Upload Source
    </a>
    <a href="/videos" class="inline-flex items-center gap-2 bg-white border border-gray-200 text-gray-700 px-4 py-2 rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors">
      <span>🎬</span> Tạo Video
    </a>
    <a href="/schedule" class="inline-flex items-center gap-2 bg-white border border-gray-200 text-gray-700 px-4 py-2 rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors">
      <span>📅</span> Lên Lịch
    </a>
  </div>
</main>
</body>
</html>
