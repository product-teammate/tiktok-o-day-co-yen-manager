<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lịch đăng — Ở Đây Có Yên</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen">
<%- include('partials/nav') %>

<main class="max-w-7xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-800">Lịch đăng</h1>
  </div>

  <!-- Schedule form -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 mb-6">
    <h2 class="font-semibold text-gray-700 mb-4">Lên lịch đăng mới</h2>
    <form id="scheduleForm" class="space-y-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-600 mb-1">Video</label>
          <select id="schedVideo" class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm">
            <option value="">— Chọn video —</option>
            <% videos.forEach(v => { %>
              <option value="<%= v.id %>"><%= v.title %> (<%= v.status %>)</option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-600 mb-1">Ngày giờ đăng</label>
          <input type="datetime-local" id="schedDate" class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm" required>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-600 mb-1">Caption</label>
          <input type="text" id="schedCaption" placeholder="Caption cho bài đăng..." class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-600 mb-1">Hashtags</label>
          <input type="text" id="schedTags" placeholder="#odaycoyen #tiktok" class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm">
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-600 mb-1">Notes</label>
        <input type="text" id="schedNotes" placeholder="Ghi chú..." class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm">
      </div>
      <button type="submit" class="bg-teal-600 text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-teal-700">Lên lịch</button>
    </form>
  </div>

  <!-- Schedule list -->
  <div class="space-y-3">
    <% if (posts.length === 0) { %>
      <div class="text-center py-12 text-gray-400 bg-white rounded-xl border border-gray-100">
        <p class="text-lg mb-2">Chưa có lịch đăng nào</p>
        <p class="text-sm">Lên lịch bài đăng đầu tiên ở trên</p>
      </div>
    <% } else { %>
      <% posts.forEach(p => { %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 flex items-center justify-between hover:shadow-md transition-shadow">
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-1">
              <span class="text-xs px-2 py-0.5 rounded-full font-medium
                <%= p.status === 'planned' ? 'bg-blue-100 text-blue-700' : '' %>
                <%= p.status === 'posted' ? 'bg-green-100 text-green-700' : '' %>
                <%= p.status === 'skipped' ? 'bg-gray-100 text-gray-600' : '' %>
              "><%= p.status %></span>
              <h3 class="text-sm font-semibold text-gray-800"><%= p.video_title || '(Chưa gắn video)' %></h3>
            </div>
            <div class="flex gap-4 text-xs text-gray-400 mt-1">
              <span>📅 <%= new Date(p.scheduled_date).toLocaleString('vi-VN') %></span>
              <% if (p.caption) { %><span>💬 <%= p.caption %></span><% } %>
              <% if (p.hashtags) { %><span><%= p.hashtags %></span><% } %>
            </div>
          </div>
          <div class="flex items-center gap-2 ml-4">
            <% if (p.status === 'planned') { %>
              <button onclick="markPosted(<%= p.id %>)" class="text-xs bg-green-50 text-green-600 px-2 py-1 rounded hover:bg-green-100">✓ Đã đăng</button>
            <% } %>
            <button onclick="deletePost(<%= p.id %>)" class="text-gray-400 hover:text-red-500 text-sm">🗑</button>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
</main>

<script>
document.getElementById('scheduleForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const res = await fetch('/api/posts', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      video_id: parseInt(document.getElementById('schedVideo').value),
      scheduled_date: document.getElementById('schedDate').value,
      caption: document.getElementById('schedCaption').value,
      hashtags: document.getElementById('schedTags').value,
      notes: document.getElementById('schedNotes').value
    })
  });
  if (res.ok) location.reload();
});

async function markPosted(id) {
  await fetch(`/api/posts/${id}`, {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ status: 'posted', posted_at: new Date().toISOString() })
  });
  location.reload();
}

async function deletePost(id) {
  if (!confirm('Xóa lịch đăng này?')) return;
  await fetch(`/api/posts/${id}`, { method: 'DELETE' });
  location.reload();
}
</script>
</body>
</html>
