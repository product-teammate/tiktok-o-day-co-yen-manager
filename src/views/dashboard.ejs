<% const body = `
<div>
  <h1 class="text-2xl font-bold mb-6">📊 Dashboard</h1>
  
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
    <div class="bg-gray-800 rounded-lg p-4">
      <div class="text-3xl font-bold text-yellow-400">${stats.draft}</div>
      <div class="text-sm text-gray-400">Draft</div>
    </div>
    <div class="bg-gray-800 rounded-lg p-4">
      <div class="text-3xl font-bold text-blue-400">${stats.scheduled}</div>
      <div class="text-sm text-gray-400">Scheduled</div>
    </div>
    <div class="bg-gray-800 rounded-lg p-4">
      <div class="text-3xl font-bold text-green-400">${stats.published}</div>
      <div class="text-sm text-gray-400">Published</div>
    </div>
    <div class="bg-gray-800 rounded-lg p-4">
      <div class="text-3xl font-bold text-purple-400">${stats.totalSources}</div>
      <div class="text-sm text-gray-400">Sources</div>
    </div>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="bg-gray-800 rounded-lg p-4">
      <h2 class="text-lg font-semibold mb-3">📅 Sắp đăng (${stats.upcoming.length})</h2>
      ${stats.upcoming.length > 0 ? '<ul class="space-y-2">' + stats.upcoming.map(p => \`
        <li class="flex justify-between items-center bg-gray-700 rounded p-2">
          <div>
            <div class="font-medium">\${p.video_title || 'No title'}</div>
            <div class="text-xs text-gray-400">\${new Date(p.scheduled_date).toLocaleString('vi-VN')}</div>
          </div>
          <span class="px-2 py-1 text-xs rounded bg-blue-900 text-blue-300">\${p.status}</span>
        </li>
      \`).join('') + '</ul>' : '<p class="text-gray-500 text-sm">Chưa có bài nào scheduled</p>'}
    </div>
    
    <div class="bg-gray-800 rounded-lg p-4">
      <h2 class="text-lg font-semibold mb-3">⚡ Quick Actions</h2>
      <div class="space-y-2">
        <a href="/sources" class="block bg-gray-700 hover:bg-gray-600 rounded p-3 transition">📁 Thêm Source mới</a>
        <a href="/videos" class="block bg-gray-700 hover:bg-gray-600 rounded p-3 transition">🎬 Tạo Video từ Sources</a>
        <a href="/schedule" class="block bg-gray-700 hover:bg-gray-600 rounded p-3 transition">📅 Lên lịch đăng bài</a>
      </div>
    </div>
  </div>
</div>
`; %>
<%- include('layout', { page: 'dashboard', title: 'Dashboard - TikTok Content Manager' }) %>
